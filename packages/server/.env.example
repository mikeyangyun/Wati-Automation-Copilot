# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# CORS_ORIGIN: comma-separated list. Trailing slashes are stripped automatically
# (browsers send `Origin` without a trailing slash, so a misconfigured
# `https://app.example.com/` would otherwise be silently rejected).
# Examples: `https://app.example.com,https://preview-*.vercel.app` or `*` (dev only).
CORS_ORIGIN=http://localhost:5173

# LLM (provider-agnostic via LLMProvider interface)
LLM_PROVIDER=deepseek
# Generate (FlowAgent) + Review (ReviewAgent.review).
#
# ⚠ Model selection matters more than it looks. DeepSeek's V4 family
# splits into two flavours that share the same API but differ 10x in
# latency on structured-output tasks like ours:
#
#   - `deepseek-chat`       → routes to v4-flash WITHOUT reasoning.
#                             ~3–8 s per Generate call. Use this.
#   - `deepseek-v4-pro`,
#     `deepseek-reasoner`   → reasoning-tuned (like OpenAI o1). Burns
#                             1500+ "thinking" tokens before any visible
#                             output, which both wastes max_tokens
#                             (mid-string JSON truncation) and inflates
#                             latency to 40+ s. DeepSeekProvider logs a
#                             warn whenever `usage.reasoning_tokens > 0`
#                             so an accidental swap surfaces in stdout.
#
# Keep `deepseek-chat` here unless you specifically want reasoning.
LLM_MODEL=deepseek-chat
# Explain (markdown summarisation). Leave unset to reuse LLM_MODEL —
# the chat model is plenty for markdown and keeps single-model
# deployments free of extra config.
LLM_FAST_MODEL=deepseek-chat
# LLM_API_KEY is required at boot unless NODE_ENV=test or LLM_PROVIDER=mock.
# Tests use MockLLMProvider; demo runs with LLM_PROVIDER=mock work without a key.
LLM_API_KEY=your-key-here
# LLM_BASE_URL leave unset to use provider default
# LLM_BASE_URL=
# 30 s is a fault-detection ceiling, not a latency budget. With
# deepseek-chat the 95th-percentile call is ~5 s; anything past 15 s
# already triggers the UI's soft "taking longer than usual" warning.
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRY=1

# Simulation
SIMULATION_MAX_RETRY=2
