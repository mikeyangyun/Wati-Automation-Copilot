# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# LLM (provider-agnostic via LLMProvider interface)
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
# LLM_API_KEY=your-key-here    # required when agents land
# LLM_BASE_URL=                  # leave unset to use provider default
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRY=1

# Simulation
SIMULATION_MAX_RETRY=2
